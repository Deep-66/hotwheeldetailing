# Email Configuration - Set up to receive booking notifications

# Option 1: Using Resend (Recommended - Free tier available)
# Get your API key from https://resend.com
RESEND_API_KEY=your_resend_api_key_here

# Admin email to receive booking notifications
ADMIN_EMAIL=admin@hotwheelsdetailing.com

# Optional: For production, also set:
# NEXT_PUBLIC_APP_URL=https://hotwheels-detailing.com
